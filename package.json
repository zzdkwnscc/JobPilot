{
  "name": "rolerover",
  "version": "1.1.0",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node scripts/dev-local.mjs",
    "dev:stack": "concurrently -k --names app,mcp --prefix-colors blue,green \"npm run dev:web\" \"npm run dev:mcp\"",
    "dev:desktop": "concurrently -k --names desktop,mcp --prefix-colors cyan,green \"electron .\" \"npm run dev:mcp\"",
    "dev:desktop-shell": "npm --prefix desktop run dev",
    "dev:tauri": "npm --prefix desktop run tauri:dev",
    "dev:tauri:local-updater": "node scripts/run-tauri-local-updater.mjs dev",
    "dev:web": "next dev --turbopack",
    "dev:mcp": "node --import tsx src/lib/ai/mcp/exa-pool-server.ts",
    "build:export-css": "tsx scripts/build-export-css.ts",
    "prebuild": "tsx scripts/build-export-css.ts",
    "build": "next build",
    "build:desktop-shell": "npm --prefix desktop run build",
    "build:tauri": "node scripts/build-tauri-desktop.mjs",
    "build:desktop:updater-feed": "node scripts/build-local-updater-feed.mjs",
    "build:desktop:release-updater-manifest": "node scripts/build-release-updater-manifest.mjs",
    "start:desktop": "electron .",
    "serve:desktop:updater-feed": "node scripts/serve-local-updater-feed.mjs",
    "build:desktop": "npm run build && electron-builder --config electron-builder.yml",
    "sync:desktop-version": "node scripts/sync-desktop-version.mjs",
    "start": "next start",
    "lint": "node scripts/verify-desktop-lint-boundary.mjs lint",
    "lint:repo:full": "eslint",
    "lint:desktop:active": "node scripts/verify-desktop-lint-boundary.mjs active",
    "lint:desktop:shared": "node scripts/verify-desktop-lint-boundary.mjs shared",
    "lint:desktop:touched": "node scripts/verify-desktop-lint-boundary.mjs touched",
    "lint:web:reference": "node scripts/verify-desktop-lint-boundary.mjs reference",
    "report:web:reference": "node scripts/verify-desktop-lint-boundary.mjs reference-report",
    "report:desktop:release-readiness": "node scripts/verify-desktop-release-readiness.mjs report",
    "verify:desktop:migration": "node scripts/verify-desktop-lint-boundary.mjs verify",
    "verify:desktop:version-sync": "node scripts/sync-desktop-version.mjs --check",
    "verify:desktop:release-readiness": "node scripts/verify-desktop-release-readiness.mjs check",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:generate:pg": "drizzle-kit generate --config drizzle-pg.config.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tauri-apps/cli",
      "better-sqlite3",
      "@swc/core",
      "sharp",
      "unrs-resolver",
      "esbuild",
      "@parcel/watcher",
      "electron",
      "electron-winstaller"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/openai": "^3.0.26",
    "@ai-sdk/react": "^3.0.80",
    "@auth/drizzle-adapter": "^1.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fingerprintjs/fingerprintjs": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sparticuz/chromium-min": "^143.0.4",
    "ai": "^6.0.78",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "docx": "^9.0.0",
    "drizzle-orm": "^0.45.1",
    "jsonrepair": "^3.13.2",
    "lucide-react": "^0.563.0",
    "mupdf": "^1.27.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.8.2",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "puppeteer-core": "^24.37.2",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "next-electron-rsc": "^0.3.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
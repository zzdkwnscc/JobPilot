{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JobPilot",
  "version": "1.1.8",
  "identifier": "com.jobpilot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JobPilot",
        "width": 1200,
        "height": 760,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "dragDropEnabled": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jlifeng/JobPilot/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4RkI4NDI3MTM0NEYyQzkKUldUSjhrUVRKNFQ3U0RMWnN6SFVDYXg5TXBrR3B5VWlDMnZlaVVBOU9LNFFnRGZWUVVaL3hnMzAK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements/macOS.entitlements",
      "signingIdentity": null
    }
  }
}

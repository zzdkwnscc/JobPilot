{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoleRover Desktop",
  "version": "1.1.0",
  "identifier": "com.rolerover.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RoleRover Desktop",
        "width": 1480,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lingshichat/RoleRover/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyMzNDODA5QjExNkEwNUUKUldSZW9CYXhDY2d6b3JkSFpucmhmS0VzOFBWZzJMVGFBOXc2SC9aZW5CaEs2QnlBQlRHL216RWwK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ]
  }
}
